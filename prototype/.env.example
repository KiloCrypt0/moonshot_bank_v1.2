# Stellar Scope — Environment Configuration
# Copy this to .env and fill in your contract IDs

# Server
PORT=4000

# History DB path (default: ./data/history.db)
# HISTORY_DB_PATH=./data/history.db

# Soroban RPC endpoint (default: gateway.fm mainnet)
SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm

# ── Blend Protocol ─────────────────────────────────────────────────────────
# Blend lending pool contract IDs (JSON array)
# Example: [{"contractId":"CABC...","name":"Main Pool"}]
BLEND_POOLS=[]

# ── Aquarius (AQUA) ───────────────────────────────────────────────────────
# Aquarius AMM router contract
AQUA_ROUTER_CONTRACT_ID=
# AQUA token contract (for reward tracking)
AQUA_TOKEN_CONTRACT_ID=
# ICE governance token contract
ICE_TOKEN_CONTRACT_ID=
# AQUA voting/locking contract
AQUA_VOTING_CONTRACT_ID=
# Known Aquarius AMM pools (JSON array)
# Example: [{"contractId":"CABC...","type":"constant_product","tokens":[{"symbol":"XLM","contractId":"C...","decimals":7},{"symbol":"USDC","contractId":"C...","decimals":7}],"rewardGauge":"CDEF..."}]
AQUA_POOLS=[]

# ── Templar Finance ───────────────────────────────────────────────────────
# Templar registry contract (discovers markets automatically)
TEMPLAR_REGISTRY_CONTRACT_ID=
# Known Templar markets (JSON array)
# Example: [{"contractId":"CABC...","name":"XLM → USDC","collateral":{"symbol":"XLM","contractId":"C...","decimals":7},"borrow":{"symbol":"USDC","contractId":"C...","decimals":7}}]
TEMPLAR_MARKETS=[]

# ── SolvBTC Token Contracts ────────────────────────────────────────────────
# Get these from stellar.expert or the Solv Protocol docs
SOLVBTC_CONTRACT_ID=
SOLVBTC_BBN_CONTRACT_ID=

# ── Solv Protocol Vaults ───────────────────────────────────────────────────
SOLV_VAULT_CONTRACT_ID=
SOLV_STAKING_CONTRACT_ID=

# Solv LP pools (JSON array)
# Example: [{"contractId":"CABC...","dex":"sushiswap-v3","token0":{"symbol":"SolvBTC","contractId":"C...","decimals":8},"token1":{"symbol":"USDC","contractId":"C...","decimals":7}}]
SOLV_LP_POOLS=[]

# ── SushiSwap V3 ──────────────────────────────────────────────────────────
SUSHI_FACTORY_CONTRACT_ID=

# Known Sushi V3 pools (JSON array)
# Example: [{"contractId":"CABC...","token0":{"contractId":"C...","symbol":"XLM","decimals":7},"token1":{"contractId":"C...","symbol":"USDC","decimals":7},"feeTier":3000}]
SUSHI_POOLS=[]
